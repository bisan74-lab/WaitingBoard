# ── 서버 ───────────────────────────────────────────────
PORT=3000
# 외부 접속 주소(QR/링크 생성에 사용). 예: https://wait.myshop.com
# Vercel에서는 보통 자동 감지되므로 비워둬도 됩니다.
PUBLIC_URL=
# 관리자 화면 접근 암호(미설정 시 개방)
ADMIN_PASSCODE=

# ── 저장소 (Vercel/서버리스 배포 시 필수) ───────────────
# 아래 KV(Redis)가 설정되면 자동으로 Redis 백엔드를 사용합니다.
# 미설정 시 파일(data/store.json) 저장 — 로컬 개발 전용.
# Vercel 대시보드에서 KV(Upstash Redis)를 연결하면 이 변수들이 자동 주입됩니다.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (Upstash를 직접 쓰는 경우 아래 이름도 인식합니다)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── 발송 업체 선택 ─────────────────────────────────────
# demo | solapi | nhncloud | aligo | kakao_memo | auto
MESSAGING_PROVIDER=demo

# ── 알림톡 공통(승인된 발신프로필/템플릿) ───────────────
# 업체별로 사용하는 변수 이름이 다릅니다. 사용하는 업체 것만 채우세요.
# 발신프로필 키/ID
ALIMTALK_PF_ID=            # Solapi (pfId)
ALIMTALK_SENDER_KEY=       # NHN Cloud / Aligo (senderKey)
# 승인 템플릿
ALIMTALK_TEMPLATE_ID=      # Solapi (templateId)
ALIMTALK_TEMPLATE_CODE=    # NHN Cloud / Aligo (templateCode)
# 대체발송(SMS)·채널 등록 발신번호
ALIMTALK_SENDER=

# ── Solapi (CoolSMS) ──────────────────────────────────
SOLAPI_API_KEY=
SOLAPI_API_SECRET=

# ── NHN Cloud (Toast) ─────────────────────────────────
NHN_ALIMTALK_APPKEY=
NHN_ALIMTALK_SECRET=
# 리전별 도메인이 다르면 지정(기본: https://api-alimtalk.cloud.toast.com)
NHN_ALIMTALK_BASE=

# ── Aligo (알리고) ────────────────────────────────────
ALIGO_API_KEY=
ALIGO_USER_ID=

# ── 카카오 나에게 보내기(연동 검증용) ──────────────────
KAKAO_ACCESS_TOKEN=
